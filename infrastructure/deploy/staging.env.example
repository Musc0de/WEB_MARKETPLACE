# -----------------------------------------------------------------------------
# STAGING ENVIRONMENT MATRIX
# -----------------------------------------------------------------------------
# Gunakan kredensial non-production (sandbox) untuk file env ini.
# Jangan pernah memasukkan file ini ke dalam public repository dengan nilai asli!

# --- DATABASE (NEON STAGING BRANCH) ---
# Dapatkan ini dari Neon Dashboard (Branch: staging)
DATABASE_URL="postgresql://user:password@ep-lively-feather-123456.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# --- REDIS (UPSTASH / LOCAL STAGING) ---
VITE_DASHBOAREDIS_URL="redis://default:password@staging-redis-url:6379"

# --- API & FRONTENDS ---
# Ganti dengan URL domain staging Anda (misal: api-staging.starsuperscare.com)
VITE_API_URL="https://api-staging.yourdomain.com"
VITE_STOREFRONT_URL="https://staging.yourdomain.com"
VITE_AUTH_URL="https://auth-staging.yourdomain.com"
VITE_DASHBOARD_URL="https://dashboard-staging.yourdomain.com"

# --- CORS & SECURITY ---
# Hanya allow origin dari domain staging.
ALLOWED_ORIGINS="https://staging.yourdomain.com,https://auth-staging.yourdomain.com,https://dashboard-staging.yourdomain.com"
SESSION_SECRET="ganti_dengan_secret_staging_yang_panjang_dan_acak_32_karakter"

# --- THIRD-PARTY SANDBOX ---
# Midtrans Sandbox
MIDTRANS_SERVER_KEY="SB-Mid-server-xxx"
MIDTRANS_CLIENT_KEY="SB-Mid-client-xxx"
MIDTRANS_IS_PRODUCTION="false"

# Resend Sandbox (jika ada)
RESEND_API_KEY="re_staging_xxx"
EMAIL_FROM="sandbox@resend.dev"
